<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Virtual Librarian</title>

<style>
@import url('https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600&display=swap');

body {
  margin: 0;
  font-family: 'Baloo 2', cursive, sans-serif;
  background: url('LargeWhiteBubble.png') no-repeat center center fixed;
  background-size: cover;
  overflow: hidden;
}

/* Scrolling banner */
.crawl {
  color: rgba(0, 0, 0, 0.7);
  padding: 8px 0;
  font-size: 36px;
  white-space: nowrap;
  overflow: hidden;
}
.crawl span {
  display: inline-block;
  padding-left: 100%;
  animation: scroll-left 25s linear infinite;
}
@keyframes scroll-left {
  from { transform: translateX(0); }
  to { transform: translateX(-100%); }
}

/* Sidebar */
.sidebar {
  position: absolute;
  top: 120px;
  left: 8%;
  color: white;
  text-shadow: 1px 1px 4px rgba(0,0,0,0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
}

.sidebar h3 {
  font-size: 26px;
  text-align: center;
  margin-bottom: 10px;
}

.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-section img {
  width: 160px;
  height: 160px;
}

/* Buttons */
.button-section {
  display: flex;
  flex-direction: column;
  gap: 18px;
  align-items: center;
}

.button-group {
  text-align: center;
}

.button-group h4 {
  margin: 0 0 6px 0;
  font-size: 24px;
}

.button-group a {
  display: inline-block;
  padding: 14px 26px;
  background: #1e3a8a;
  color: white;
  font-size: 24px;
  font-weight: 600;
  text-decoration: none;
  border-radius: 12px;
  box-shadow: 0 0 8px rgba(0,0,0,0.5);
  transition: background 0.3s ease, transform 0.2s ease;
  cursor: pointer;
}

.button-group a:hover {
  background: #3b82f6;
  transform: scale(1.05);
}

/* Chatbot */
.chatbot {
  position: absolute;
  top: 12%;
  left: 50%;
  transform: translateX(-50%);
  width: 20.5vw;
  height: 80vh;
  border: none;
  border-radius: 20px;
  box-shadow: 0 0 10px rgba(0,0,0,0.25);
  background: transparent;
}

/* Mobile */
@media (max-width: 800px) {
  .sidebar {
    position: static;
    text-align: center;
    margin-top: 20px;
  }

  .chatbot {
    position: relative;
    transform: none;
    width: 90vw;
    height: 75vh;
    margin: 20px auto;
  }
}
</style>
</head>

<body>

<div class="crawl">
  <span>⚠️ AI may give incorrect or outdated information — verify important details. • Never share personal or sensitive data. • This chatbot is a support tool, not a replacement for professional advice.</span>
</div>

<div class="sidebar">

  <div class="qr-section">
    <h3>Check us out on YouTube</h3>
    <img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=https://www.youtube.com/c/mrevans">
  </div>

  <div class="button-section">

    <div class="button-group">
      <h4>Our Library Catalog</h4>
      <a onclick="openSmallPopup('https://busdlibrary.follettdestiny.com/portal/portal?app=Destiny%20Discover&appId=destiny-HGDN-TZ6F&siteGuid=7E2D9B06-9998-4EAF-AF9A-AE1C13D1FC38&nav=https:%2F%2Fbusdlibrary.follettdestiny.com%2Fmetasearch%2Fui%2F32225')">
        🔎 Destiny Portal
      </a>
    </div>

    <div class="button-group">
      <h4>Our eBook Catalog</h4>
      <a onclick="openSmallPopup('https://soraapp.com/library/bellflower')">
        📚 Sora Library
      </a>
    </div>

  </div>
</div>

<iframe
  class="chatbot"
  src="https://www.playlab.ai/embedded/cma1lng2i17v6rgigh3onpno7"
  allow="clipboard-write">
</iframe>

<script>
function openSmallPopup(url) {
  const w = Math.floor(window.innerWidth / 3);
  const h = Math.floor(window.innerHeight / 3);

  const left = Math.floor((window.innerWidth - w) / 2);
  const top = Math.floor((window.innerHeight - h) / 2);

  const features =
    `width=${w},height=${h},left=${left},top=${top},resizable=yes,scrollbars=yes`;

  const win = window.open(url, "_blank", features);

  // fallback if popup blocked
  if (!win) {
    window.location.href = url;
  }
}
</script>

</body>
</html>
